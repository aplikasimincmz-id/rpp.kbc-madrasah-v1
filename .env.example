# ============================================
# KONFIGURASI ENVIRONMENT VARIABLES
# ============================================
# Copy file ini menjadi .env dan isi nilainya
# cp .env.example .env
# ============================================

# Database PostgreSQL (WAJIB)
# Untuk lokal: postgresql://postgres:postgres@127.0.0.1:5432/app_db
# Untuk Neon:  postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# JWT Secret untuk autentikasi (WAJIB)
# Generate dengan: openssl rand -base64 32
JWT_SECRET=ganti-dengan-string-rahasia-anda
